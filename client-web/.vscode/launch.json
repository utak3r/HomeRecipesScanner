{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Debug via NPM (Vite)",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "preLaunchTask": "npm: dev"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch via Nginx (Docker)",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "docker-compose: up"
    }
  ]
}
